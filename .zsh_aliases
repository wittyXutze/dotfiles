# zsh aliases

setopt AUTO_CD

alias pcb='/home/withold/Leiterplatten'
#alias pcb='cd /mnt/sdb1/Leiterplatten'
#alias Leiterplatten=/mnt/sdb1/Leiterplatten

alias xyz='nmap -n -sn 192.168.11.0/24 -oG - | awk "'"/Up$/{print $2}"'"'
      rxvt='urxvt -fg '"'"'#111111'"'"' -bg '"'"'#111111'"'"

alias zshrc='code ~/.zshrc'
alias source_zsh='source ~/.zshrc'

alias OS='uname -r'
alias welcheversion='lsb_release -d && uname -r'

alias gp='git pull'
alias gc='git clone '
alias lg='lazygit'
alias z='zoxide'

alias pacsear="pacman -Slq | sk --multi --preview 'pacman -Si {1}'"
alias pacsearin="pacman -Slq | sk --multi --preview 'pacman -Si {1}' | xargs -ro sudo pacman -S"
alias yasear="yay -Slq | sk --multi --preview 'yay -Si {1}'"
alias yasearin="yay -Slq | sk --multi --preview 'yay -Si {1}' | xargs -rp yay -S"

# Ordner zuerst anzeigen:
alias ls='ls --group-directories-first'
